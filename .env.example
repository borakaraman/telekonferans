# Bu dosyayi ".env.local" olarak kopyalayin ve kendi degerlerinizle doldurun.
#   cp .env.example .env.local        (macOS/Linux)
#   copy .env.example .env.local      (Windows)
# .env.local git'e GONDERILMEZ (.gitignore ile haric tutulur) — gizli anahtarlar guvende.

# --- LiveKit ---
# Yerel test (Docker dev sunucusu) icin varsayilan anahtarlar:
#   LIVEKIT_API_KEY=devkey
#   LIVEKIT_API_SECRET=secret
#   NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
#   LIVEKIT_URL=ws://localhost:7880
# Iki cihazli gercek test icin LiveKit Cloud (https://cloud.livekit.io) kullanin:
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud

# --- Gemini Live API ---
# Anahtari https://aistudio.google.com/apikey adresinden alin.
GEMINI_API_KEY=your-gemini-api-key
